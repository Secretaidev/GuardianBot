# ╔══════════════════════════════════════════════════╗
# ║        ɢᴜᴀʀᴅɪᴀɴʙᴏᴛ - Environment Config           ║
# ║   Copy this file to .env and fill in the values   ║
# ╚══════════════════════════════════════════════════╝

# ─────────────────────────────────────────
# 🔑 REQUIRED VARIABLES
# ─────────────────────────────────────────

# Your Telegram Bot Token
# Get this from @BotFather on Telegram by sending /newbot
# Example: 1234567890:ABCDefGHIjklMNOpqrsTUVwxYZ
BOT_TOKEN=your_bot_token_here

# MongoDB Atlas Connection String
# Create a free cluster at https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/
# Make sure to allow all IPs (0.0.0.0/0) in Network Access
MONGO_URI=mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/

# Private Log Channel ID
# 1. Create a private Telegram channel
# 2. Add your bot as an administrator with all permissions
# 3. Forward a message from the channel to @userinfobot to get the ID
# 4. The ID is always a negative number like -1001234567890
LOG_CHANNEL_ID=-100xxxxxxxxxx

# Your Telegram User ID (numeric, not your username)
# Send /start to @userinfobot to get your numeric user ID
# Example: 123456789
OWNER_ID=your_telegram_id_here

# ─────────────────────────────────────────
# ⚙️ OPTIONAL VARIABLES
# ─────────────────────────────────────────

# Display name for the bot (used in messages and logs)
BOT_NAME=GuardianBot

# Bot's Telegram username WITHOUT the @ symbol
# Example: MyGroupBot
# BOT_USERNAME=GuardianGroupBot

# Comma-separated list of Telegram user IDs that have sudo/superadmin access
# These users can use all admin commands in any group
# Example: 123456789,987654321
# SUDO_USERS=

# Maximum number of warnings before a user is actioned (banned/muted)
# Default is 3 warnings
WARN_LIMIT=3

# Default mute duration in minutes when auto-action on warn limit is mute
# Default is 60 minutes (1 hour)
# WARN_MUTE_DURATION=60

# Default warn action: "ban", "kick", or "mute"
# What happens when a user reaches the warn limit
# WARN_ACTION=ban

# Anti-flood: Maximum messages allowed in the flood window
# Set to 0 to disable anti-flood globally
# FLOOD_LIMIT=5

# Anti-flood: Time window in seconds to count messages for flood detection
# FLOOD_TIME=5

# MongoDB database name (default: guardianbot)
# DB_NAME=guardianbot

# Cache TTL in seconds for group settings (default: 300 = 5 minutes)
# CACHE_TTL=300

# Whether to delete the bot's own command messages after a delay (true/false)
# DELETE_COMMANDS=false

# Delay in seconds before deleting command messages (if DELETE_COMMANDS=true)
# DELETE_DELAY=5
